---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ForgotPasswordForm from "@/components/auth/ForgotPasswordForm";
---

<BaseLayout title="Forgot password — H Studio" description="Reset your H Studio password (demo).">
  <section class="container" style="padding-block: var(--space-8); max-width: 480px;">
    <div class="stack-md">
      <div class="pill">Account</div>
      <h1 style="margin: 0;">Reset password</h1>
      <p class="muted" style="margin: 0;">Later you can hook this form to your auth provider’s reset flow.</p>
      <div class="card" style="padding: 24px; box-shadow: none; transform: none;">
        <ForgotPasswordForm client:load />
      </div>
      <p class="muted" style="font-size: 14px;">
        Remembered it? <a href="/login">Back to log in</a>
      </p>
    </div>
  </section>
</BaseLayout>
