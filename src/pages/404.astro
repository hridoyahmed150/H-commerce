---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Not found — H Studio">
  <section class="container stack-md" style="padding-block: var(--space-9); text-align: center;">
    <div class="pill">404</div>
    <h1 style="margin: 0;">We can’t find that page</h1>
    <p class="muted" style="margin: 0;">The product or route may have moved.</p>
    <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
      <a class="btn btn-primary" href="/products">Browse products</a>
      <a class="btn btn-ghost" href="/">Go home</a>
    </div>
  </section>
</BaseLayout>
