---
const year = new Date().getFullYear();
---

<footer style="margin-top: auto; border-top: 1px solid var(--border); padding: var(--space-7) 0;">
  <div class="container" style="display:flex;flex-wrap:wrap;gap:var(--space-6);justify-content:space-between;align-items:center;">
    <div class="muted" style="max-width: 420px;">
      <strong style="color: var(--text);">H Commerce</strong> — a backend-agnostic storefront shell. Swap services when your API is ready.
    </div>
    <div class="muted">© {year} H Commerce</div>
  </div>
</footer>
